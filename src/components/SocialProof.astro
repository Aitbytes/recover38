---
---

<section id="social-proof" class="py-16 sm:py-24 px-4 bg-surface">
  <div class="max-w-3xl mx-auto">
    <h2
      class="font-heading font-bold text-title text-primary text-center mb-12"
      data-reveal
    >
      The Transformation
    </h2>

    <!-- Before/After Cards -->
    <div class="grid md:grid-cols-2 gap-8">
      <!-- Before -->
      <div 
        class="bg-surface-alt rounded-2xl p-8 border border-border"
        data-reveal
        data-reveal-delay="1"
      >
        <h3 class="font-heading font-semibold text-lg text-text-muted mb-4">Before Recover38</h3>
        <blockquote class="text-xl text-text-main leading-relaxed mb-6 italic">
          "I trained at 6pm, came home exhausted, and spent the next 2 hours on the couch unable to do anything useful. My evening was recovery, not life."
        </blockquote>
        <div class="flex items-center gap-2 text-text-muted">
          <svg class="w-5 h-5" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd" />
          </svg>
          <span class="text-sm">6pm workout → 2+ hours on the couch</span>
        </div>
      </div>

      <!-- After -->
      <div 
        class="bg-primary/5 rounded-2xl p-8 border-2 border-primary/20"
        data-reveal
        data-reveal-delay="2"
      >
        <h3 class="font-heading font-semibold text-lg text-primary mb-4">After Recover38</h3>
        <blockquote class="text-xl text-text-main leading-relaxed mb-6 italic">
          "Now I finish at 7pm, mix my Recover38, and I'm making dinner by 7:30. I'm not energized — I'm just... functional. Which is exactly what I needed."
        </blockquote>
        <div class="flex items-center gap-2 text-primary">
          <svg class="w-5 h-5" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
          </svg>
          <span class="text-sm font-medium">7pm workout → dinner with family</span>
        </div>
      </div>
    </div>

    <!-- Who It's For -->
    <div 
      class="mt-12 bg-surface-alt rounded-2xl p-8 border border-border"
      data-reveal
      data-reveal-delay="3"
    >
      <h3 class="font-heading font-semibold text-xl text-primary mb-6 text-center">Who Recover38 Is For</h3>
      <div class="grid sm:grid-cols-2 gap-4">
        <div class="flex items-start gap-3">
          <span class="w-2 h-2 rounded-full bg-accent mt-2 flex-shrink-0"></span>
          <p class="text-text-muted">You workout 3-5x/week and feel wrecked between sessions</p>
        </div>
        <div class="flex items-start gap-3">
          <span class="w-2 h-2 rounded-full bg-accent mt-2 flex-shrink-0"></span>
          <p class="text-text-muted">You experience "jittery muscles" or tremors post-workout</p>
        </div>
        <div class="flex items-start gap-3">
          <span class="w-2 h-2 rounded-full bg-accent mt-2 flex-shrink-0"></span>
          <p class="text-text-muted">Brain fog hits after intense training</p>
        </div>
        <div class="flex items-start gap-3">
          <span class="w-2 h-2 rounded-full bg-accent mt-2 flex-shrink-0"></span>
          <p class="text-text-muted">You're tired of products that don't explain what they do</p>
        </div>
      </div>
    </div>
  </div>
</section>
