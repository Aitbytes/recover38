---
interface ValueProp {
  title: string;
  description: string;
  icon: string;
}

const valueProps: ValueProp[] = [
  {
    title: "Stop Sitting Around Recovering",
    description: "You trained hard. Now your muscles are shaking and your brain is foggy. Recover38 gets you back to your life — not just back to baseline by tomorrow morning.",
    icon: "clock",
  },
  {
    title: "No Black-Box Formulas",
    description: "Every ingredient is listed with its exact purpose. Magnesium glycinate for muscle tension. L-theanine for mental clarity. Taurine for neural recovery. No 'proprietary blend' mystery.",
    icon: "flask",
  },
  {
    title: "No Subscription Lock-In",
    description: "Try it month-to-month. Cancel anytime with one email. Unlike WHOOP and their $239/year 'cancel anytime (good luck),' we believe your money should flow when you want it to.",
    icon: "unlock",
  },
];

const icons: Record<string, string> = {
  clock: `<svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12,6 12,12 16,14"/></svg>`,
  flask: `<svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 3h6M10 3v6.5L5 21h14l-5-11.5V3"/><path d="M7 21h10"/></svg>`,
  unlock: `<svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 9.9-1"/></svg>`,
};
---

<section id="value-props" class="py-16 sm:py-24 px-4 bg-surface-alt">
  <div class="max-w-6xl mx-auto">
    <div class="grid md:grid-cols-3 gap-6 sm:gap-8">
      {valueProps.map((prop, index) => (
        <article
          class="bg-surface p-8 rounded-2xl border border-border shadow-card hover:shadow-card-hover hover:-translate-y-1 transition-all duration-300"
          data-reveal
          data-reveal-delay={String(Math.min(index + 1, 5))}
        >
          <!-- Icon -->
          <div class="w-14 h-14 rounded-xl bg-primary/10 flex items-center justify-center text-primary mb-6">
            <Fragment set:html={icons[prop.icon]} />
          </div>
          
          <!-- Title -->
          <h3 class="font-heading font-semibold text-xl text-primary mb-3 leading-snug">
            {prop.title}
          </h3>
          
          <!-- Description -->
          <p class="text-text-muted leading-relaxed">
            {prop.description}
          </p>
        </article>
      ))}
    </div>
  </div>
</section>
